{
	frankenphp
	order php_server before file_server

	# Cloudflare está em modo "Full (strict)" na frente (edge já serve
	# HTTPS ao visitante) — a origem usa um certificado Cloudflare Origin
	# CA (não pública), então desligamos o ACME automático do Caddy e
	# fornecemos o cert manualmente via diretiva `tls` em cada site.
	auto_https disable_certs
}

# API Laravel.
{$API_DOMAIN:localhost} {
	tls /etc/caddy/certs/cloudflare-origin.pem /etc/caddy/certs/cloudflare-origin.key

	root * /app/public

	encode zstd br gzip

	php_server

	file_server
}

# Frontend Next.js — este container atua como ingress único do VPS,
# fazendo reverse proxy para o serviço "frontend" na rede interna do
# Compose (evita expor uma segunda porta/TLS para o Next.js).
{$APP_DOMAIN:app.localhost} {
	tls /etc/caddy/certs/cloudflare-origin.pem /etc/caddy/certs/cloudflare-origin.key

	encode zstd br gzip

	reverse_proxy frontend:3000
}
