{
	frankenphp
	order php_server before file_server

	# Cloudflare runs in "Full (strict)" mode in front (edge already serves
	# HTTPS to visitors). The origin uses a Cloudflare Origin CA certificate
	# (not publicly trusted), so we disable Caddy automatic ACME and
	# provide the certificate manually via the tls directive on each site.
	auto_https disable_certs
}

# Laravel API.
{$API_DOMAIN:localhost} {
	tls /etc/caddy/certs/cloudflare-origin.pem /etc/caddy/certs/cloudflare-origin.key

	root * /app/public

	encode zstd br gzip

	php_server

	file_server
}

# Next.js frontend. This container acts as the single VPS ingress,
# reverse proxying to the "frontend" service on the internal Compose
# network (avoids exposing a second port/TLS endpoint for Next.js).
{$APP_DOMAIN:app.localhost} {
	tls /etc/caddy/certs/cloudflare-origin.pem /etc/caddy/certs/cloudflare-origin.key

	encode zstd br gzip

	reverse_proxy frontend:3000
}
